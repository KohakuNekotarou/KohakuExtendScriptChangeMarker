/*  
 * Plugin version definition.
 */
resource PluginVersion (kSDKDefPluginVersionResourceID)
{
	kTargetVersion,
	kKESCMPluginID,
	kSDKDefPlugInMajorVersionNumber, kSDKDefPlugInMinorVersionNumber,
	kSDKDefHostMajorVersionNumber, kSDKDefHostMinorVersionNumber,
	kKESCMCurrentMajorFormatNumber, kKESCMCurrentMinorFormatNumber,
	{ kInDesignProduct },
	{ kWildFS },
	kUIPlugIn,
	kKESCMVersion
};

/*  
 * The ExtraPluginInfo resource adds extra information to the Missing Plug-in dialog
 * that is popped when a document containing this plug-in's data is opened when
 * this plug-in is not present. These strings are not translatable strings
 * since they must be available when the plug-in isn't around. They get stored
 * in any document that this plug-in contributes data to.
 */
resource ExtraPluginInfo(1)
{
	kKESCMCompanyValue,			// Company name
	kKESCMMissingPluginURLValue,	// URL 
	kKESCMMissingPluginAlertValue,	// Missing plug-in alert text
};

/* 
 * Boss class definitions.
 */
resource ClassDescriptionTable(kSDKDefClassDescriptionTableResourceID)
{{{
	Class
	{
		kKESCMScriptProviderBoss,
		kBaseScriptProviderBoss,
		{
			IID_ISCRIPTPROVIDER,kKESCMScriptProviderImpl,
			
		}
	},

	Class
	{
		kKESCMDrawEventServiceBoss,
		kInvalidClass,
		{
			IID_IK2SERVICEPROVIDER, kKESCMDrawEventSrvcImpl,
			IID_IDRWEVTHANDLER,     kKESCMDrawEventHandlerImpl,
		}
	},

	// Middle-button "peek": snoops kMButtonDn/kMButtonUp (non-consuming) and, while armed,
	// shows the opaque OLD overlay of the spread under the mouse while the button is held.
	Class
	{
		kKESCMPeekWatcherBoss,
		kInvalidClass,
		{
			IID_IEVENTWATCHER, kKESCMPeekWatcherImpl,
		}
	},

	// Starts the peek watcher at app launch (lazy = during an idle task right after startup).
	Class
	{
		kKESCMPeekStartupBoss,
		kInvalidClass,
		{
			IID_ISTARTUPSHUTDOWN,   kKESCMPeekStartupImpl,
			IID_IK2SERVICEPROVIDER, kLazyStartupShutdownProviderImpl,
		}
	},

	// Auto-dismissing on-canvas toast: an idle task that hides the toast message after a delay.
	Class
	{
		kKESCMToastIdleTaskBoss,
		kInvalidClass,
		{
			IID_IIDLETASK, kKESCMToastIdleTaskImpl,
		}
	},

	// Action component: handles the About menu items (main menu + panel flyout).
	Class
	{
		kKESCMActionComponentBoss,
		kBaseActionComponentBoss,
		{
			IID_IACTIONCOMPONENT, kKESCMActionComponentImpl,
		}
	},

	// The ChangeMarker control panel (palette). The observer drives the Start/Clear/print controls
	// and the popup (flyout) menu data hosts the "About this plug-in" item.
	Class
	{
		kKESCMPanelWidgetBoss,
		kPalettePanelWidgetBoss,
		{
			IID_IPANELMENUDATA, kCPanelMenuDataImpl,
			IID_IOBSERVER, kKESCMPanelObserverImpl,
		}
	},

	// Document-close responder service. IK2ServiceProvider advertises the after-close
	// signal; IResponder cleans up any of KESCM's tracked, now-closed documents.
	Class
	{
		kKESCMDocResponderServiceBoss,
		kInvalidClass,
		{
			IID_IK2SERVICEPROVIDER, kKESCMDocServiceProviderImpl,
			IID_IRESPONDER,         kKESCMDocResponderImpl,
		}
	},
}}};

