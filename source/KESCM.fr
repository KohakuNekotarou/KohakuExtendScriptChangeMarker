// Strings not being localized
resource StringTable (kSDKDefStringsNoTransResourceID + index_enUS)
{
	k_enUS,									// Locale Id
	kEuropeanMacToWinEncodingConverter,		// Character encoding converter
	{
		// Internal popup (flyout) menu name - not translated.
		kKESCMInternalPopupMenuNameKey,	kKESCMInternalPopupMenuNameKey,
	}
};
/*

/*  Scripting definition
	In InDesign/InCopy, scripting resources are defined via ODFRez statements for cross-platform compatibility.
*/
resource VersionedScriptElementInfo(2)
{
	// Contexts
	{
        kFiredrakeScriptVersion, kCoreScriptManagerBoss, kInDesignAllLanguagesFS, k_Wild,
		kFiredrakeScriptVersion, kCoreScriptManagerBoss, kInCopyAllLanguagesFS, k_Wild,
		
	}
	
	// Elements
	{
			// Page/Document.kescmToast(message) - shows a brief message at the CENTER of the visible area that
			// auto-dismisses after ~2.5s. Screen only, non-persistent.
			// ExtendScript:  app.documents[0].kescmToast("ChangeMarker ON");
			Method
			{
				kKESCMToastMethodScriptElement,
				e_KESCMToast,
				"kescm toast",
				"Shows a brief auto-dismissing message at the center of the screen (screen only).",
				StringType,
				"Status string",
				{
					p_KESCMToastMsg, "message", "The text to show briefly at the center of the screen", StringType, kRequired,
				}
			}

			// Connects this plug-in's methods to scripting. kescmToast targets the document's
			// layout window (centered in the visible area), so it is exposed on the Document object only.
			Provider
		{
			kKESCMScriptProviderBoss,	// provider boss ID
			{
				Object{ kDocumentObjectScriptElement },
				Method{ kKESCMToastMethodScriptElement },
			}
		}
	}
};


//========================================================================================
// ChangeMarker control panel (palette)
//========================================================================================

// PNG icons (compiled into the plug-in; ON = armed/comparing, OFF = idle). Same art is used for
// the normal and rollover states since this is a non-interactive status icon.
resource PNGA(kKESCMIconOnResID)  "KohakuExtendScriptChangeMarkerON64.png"
resource PNGR(kKESCMIconOnResID)  "KohakuExtendScriptChangeMarkerON64.png"
resource PNGA(kKESCMIconOffResID) "KohakuExtendScriptChangeMarkerOFF64.png"
resource PNGR(kKESCMIconOffResID) "KohakuExtendScriptChangeMarkerOFF64.png"

// Small dock-tab icon shown when the panel is collapsed to its smallest. Replace
// KohakuChangeMarkerTab.png with your own artwork (a small, e.g. ~20x20, transparent PNG).
resource PNGA(kKESCMPaletteIconResID) "KohakuChangeMarkerTab.png"

// Panel LocaleIndex - a single (string-key driven) view is used for every locale; the labels
// themselves are localized through the string tables (KESCM_enUS.fr / KESCM_jaJP.fr).
resource LocaleIndex (kSDKDefPanelResourceID)
{
	kViewRsrcType,
	{
		kWildFS, k_Wild, kSDKDefPanelResourceID + index_enUS
	}
};

// Type definition for the panel widget boss.
type KESCMPanelWidget(kViewRsrcType) : PalettePanelWidget(ClassID = kKESCMPanelWidgetBoss)
{
	CPanelMenuData;
};

// PanelList - registers the panel and makes it appear under the Window menu.
resource PanelList (kSDKDefPanelResourceID)
{
	{
		kSDKDefPanelResourceID,		// Resource ID for this panel
		kKESCMPluginID,				// owning plug-in
		kNotResizable,				// fixed-size panel
		kKESCMPanelWidgetActionID,	// Action ID to show/hide the panel
		"",							// panelName empty: place via altMenu below for explicit menu placement
		kKESCMPanelPluginsMenuPath,	// Plug-Ins > KohakuNekotarou > KohakuChangeMarker
		kKESCMPanelPluginsMenuPosition,	// lower part of the menu
		kKESCMPaletteIconResID, kKESCMPluginID,	// PNG icon for the collapsed dock tab
		c_Panel
	}
};

// PanelView - widget layout. Labels reference string keys so they localize automatically.
resource KESCMPanelWidget(kSDKDefPanelResourceID + index_enUS)
{
	__FILE__, __LINE__,
	kKESCMPanelWidgetID,			// WidgetID
	kPMRsrcID_None,					// RsrcID
	kBindNone,						// Binding
	0, 0, 192, 300,					// Frame: left, top, right, bottom (width 80% of original 240)
	kTrue, kTrue,					// Visible, Enabled
	kFalse,							// Erase background
	kInterfacePaletteFill,			// Erase to color
	kFalse,							// Draw dropshadow
	kKESCMPanelTitleKey,			// Panel name
	{
		// Target / Source status (label stays English; the document name is filled in by the observer).
		StaticTextWidget
		(
			kKESCMTargetTextWidgetID,
			kSysStaticTextPMRsrcId,
			kBindLeft | kBindRight | kBindTop,
			Frame(8, 8, 184, 24)
			kTrue, kTrue,
			kAlignLeft, kEllipsizeEnd, kTrue,
			kKESCMTargetLabelKey,
			kInvalidWidgetID,
		),
		StaticTextWidget
		(
			kKESCMSourceTextWidgetID,
			kSysStaticTextPMRsrcId,
			kBindLeft | kBindRight | kBindTop,
			Frame(8, 26, 184, 42)
			kTrue, kTrue,
			kAlignLeft, kEllipsizeEnd, kTrue,
			kKESCMSourceLabelKey,
			kInvalidWidgetID,
		),

		// Separator.
		SeparatorWidget
		(
			kInvalidWidgetID, kPMRsrcID_None,
			kBindLeft | kBindRight | kBindTop,
			Frame(0, 48, 192, 50)
			kTrue, kTrue,
		),

		// Start / Stop toggle button. The observer flips the label between
		// "Start" (idle) and "Stop" (armed/comparing) based on the shared state.
		ButtonWidget
		(
			kKESCMToggleButtonWidgetID,
			kSysButtonPMRsrcId,
			kBindLeft | kBindRight | kBindTop,
			Frame(12, 56, 180, 80)
			kTrue, kTrue,
			kKESCMStartButtonKey,
		),

		// Print marks checkbox.
		CheckBoxWidget
		(
			kKESCMPrintCheckWidgetID,
			kSysCheckBoxPMRsrcId,
			kBindLeft | kBindTop,
			Frame(12, 88, 180, 104)
			kTrue, kTrue,
			kAlignLeft,
			kKESCMPrintCheckKey,
		),

		// Print opacity (25% / Normal). Order 25% -> Normal, default 25% (set by the observer).
		ClusterPanelWidget
		(
			kKESCMOpacityClusterWidgetID,
			kPMRsrcID_None,
			kBindLeft | kBindTop,
			Frame(12, 110, 180, 160)
			kTrue, kTrue,
			"",
			{
				RadioButtonWidget
				(
					kKESCMOpacity25RadioWidgetID,
					kSysRadioButtonPMRsrcId,
					kBindNone,
					Frame(6, 4, 160, 20)
					kTrue, kTrue,
					kKESCMOpacity25Key,
				),
				RadioButtonWidget
				(
					kKESCMOpacityNormalRadioWidgetID,
					kSysRadioButtonPMRsrcId,
					kBindNone,
					Frame(6, 24, 160, 40)
					kTrue, kTrue,
					kKESCMOpacityNormalKey,
				),
			}
		),

		// Status icon (OFF visible by default; the observer swaps ON/OFF based on the armed state).
		RollOverIconButtonWidget
		(
			kKESCMIconOffWidgetID,
			kKESCMIconOffResID, kKESCMPluginID,
			kBindBottom,
			Frame(64, 228, 128, 292)
			kTrue, kTrue,
			kADBEIconSuiteButtonType,
		),
		RollOverIconButtonWidget
		(
			kKESCMIconOnWidgetID,
			kKESCMIconOnResID, kKESCMPluginID,
			kBindBottom,
			Frame(64, 228, 128, 292)
			kFalse, kTrue,
			kADBEIconSuiteButtonType,
		),

		// Status text (filled in by the observer with the result of each action).
		StaticMultiLineTextWidget
		(
			kKESCMStatusTextWidgetID,
			kPMRsrcID_None,
			kBindLeft | kBindRight | kBindTop,
			Frame(8, 168, 184, 220)
			kTrue, kTrue,
			kAlignLeft, kDontEllipsize, kTrue,
			kInvalidWidgetID,
			kPaletteWindowFontId,
			3,
			2, 0,
			"",
		),
	}

	kKESCMInternalPopupMenuNameKey		// Popup (flyout) menu name (internal)
};

