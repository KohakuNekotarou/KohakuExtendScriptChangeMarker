/*
 * Menu definition: the About Plug-ins entry (main menu) and the "About this plug-in" entry on
 * the panel's flyout (popup) menu. The panel itself appears under the Window menu automatically
 * (registered via the PanelList resource below), so no menu entry is needed for showing it.
 */
resource MenuDef (kSDKDefMenuResourceID)
{
	{
		// About Plug-ins sub-menu item.
		kKESCMAboutActionID,
		kKESCMAboutMenuPath,
		kSDKDefAlphabeticPosition,
		kSDKDefIsNotDynamicMenuFlag,

		// "About this plug-in" on the panel flyout (popup) menu.
		kKESCMPopupAboutThisActionID,
		kKESCMPopupMenuPath,
		kKESCMAboutThisMenuItemPosition,
		kSDKDefIsNotDynamicMenuFlag,
	}
};

/*
 * Action definition for the menu items above.
 */
resource ActionDef (kSDKDefActionResourceID)
{
	{
		kKESCMActionComponentBoss,			// boss that implements the action
		kKESCMAboutActionID,				// ActionID
		kKESCMAboutMenuKey,					// sub-menu string
		kHelpMenuActionArea,				// area name
		kNormalAction,						// action type
		kDisableIfLowMem,					// enabling type
		kInvalidInterfaceID,				// selection interface this action cares about
		kSDKDefInvisibleInKBSCEditorFlag,	// KBSC editor visibility

		kKESCMActionComponentBoss,
		kKESCMPopupAboutThisActionID,
		kSDKDefAboutThisPlugInMenuKey,
		kOtherActionArea,
		kNormalAction,
		kDisableIfLowMem,
		kInvalidInterfaceID,
		kSDKDefInvisibleInKBSCEditorFlag,
	}
};


