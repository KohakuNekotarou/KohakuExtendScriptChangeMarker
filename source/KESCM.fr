// Strings not being localized
resource StringTable (kSDKDefStringsNoTransResourceID + index_enUS)
{
	k_enUS,									// Locale Id
	kEuropeanMacToWinEncodingConverter,		// Character encoding converter
	{
		// Internal popup (flyout) menu name - not translated.
		kKESCMInternalPopupMenuNameKey,	kKESCMInternalPopupMenuNameKey,
	}
};
/*

/*  Scripting definition
	In InDesign/InCopy, scripting resources are defined via ODFRez statements for cross-platform compatibility.
*/
resource VersionedScriptElementInfo(2)
{
	// Contexts
	{
        kFiredrakeScriptVersion, kCoreScriptManagerBoss, kInDesignAllLanguagesFS, k_Wild,
		kFiredrakeScriptVersion, kCoreScriptManagerBoss, kInCopyAllLanguagesFS, k_Wild,
		
	}
	
	// Elements
	{
		// Page.kescmClearMarks() - removes the change-mark overlay shown on this page.
		// ExtendScript:  doc1.spreads[0].pages[0].kescmClearMarks();
		Method
		{
			kKESCMClearMarksMethodScriptElement,
			e_KESCMClearMarks,
			"kescm clear marks",
			"Clears the change-mark overlay shown on this page.",
			StringType,
			"Status string",
			{}
		}

		// Document.kescmMarkChangesDoc(sourceDoc) - compares each page of THIS document against the
		// corresponding page (by index) of sourceDoc and marks all changed pages with the red ring.
		// Unchanged pages get no overlay. Screen only, non-persistent.
		// ExtendScript:  app.documents[0].kescmMarkChangesDoc(app.documents[1]);
		Method
		{
			kKESCMMarkChangesDocMethodScriptElement,
			e_KESCMMarkChangesDoc,
			"kescm mark changes doc",
			"Marks changed pages of this document against the given source document (screen only).",
			StringType,
			"Status string",
			{
				p_KESCMSourceDoc, "KESCM source document", "The document to compare against (page i vs page i)", ObjectType(kDocumentObjectScriptElement), kRequired,
			}
		}

			// Document.kescmArmMousePeek(sourceDoc) - arms the middle-button "peek". After arming, holding the
			// MIDDLE mouse button overlays the OLD version of the spread under the cursor (rasterized on the fly);
			// releasing the button hides it. The image cache is kept for the most recently peeked spread (instant
			// re-peek). Pass the OLD document to compare against. Screen only, non-persistent.
			// ExtendScript:  app.documents[0].kescmArmMousePeek(app.documents[1]);
			Method
			{
				kKESCMArmMousePeekMethodScriptElement,
				e_KESCMArmMousePeek,
				"kescm arm mouse peek",
				"Arms the middle-button peek of the old version of the spread under the mouse (screen only).",
				StringType,
				"Status string",
				{
					p_KESCMSourceDoc, "KESCM source document", "The old document whose page images are overlaid while peeking (page i vs page i)", ObjectType(kDocumentObjectScriptElement), kRequired,
				}
			}

			// Document.kescmDisarmMousePeek() - disarms the middle-button peek, hides any overlay and frees the
			// cached old-version images. ExtendScript:  app.documents[0].kescmDisarmMousePeek();
			Method
			{
				kKESCMDisarmMousePeekMethodScriptElement,
				e_KESCMDisarmMousePeek,
				"kescm disarm mouse peek",
				"Disarms the middle-button peek and frees the cached old-version images (screen only).",
				StringType,
				"Status string",
				{}
			}

			// Page/Document.kescmToast(message) - shows a brief message at the CENTER of the visible area that
			// auto-dismisses after ~2.5s. Screen only, non-persistent.
			// ExtendScript:  app.documents[0].kescmToast("ChangeMarker ON");
			Method
			{
				kKESCMToastMethodScriptElement,
				e_KESCMToast,
				"kescm toast",
				"Shows a brief auto-dismissing message at the center of the screen (screen only).",
				StringType,
				"Status string",
				{
					p_KESCMToastMsg, "message", "The text to show briefly at the center of the screen", StringType, kRequired,
				}
			}

			// Page/Document.kescmSetPrintMarks([flag]) - makes the change marks (red rings + change counts) appear when
			// PRINTING. While ON, the marks also stay visible on screen at all times (WYSIWYG), independent of the
			// middle-button press reveal. Pass false to make them screen-only again. The flag is optional (omit to turn
			// printing ON). Marks data is untouched; only the print/visibility behavior changes.
			// NOTE: File > Export > PDF does NOT dispatch the spread draw event, so marks do not appear there; to get a
			// PDF with the marks, use File > Print to a "Print to PDF" printer (that goes through the print pipeline).
			// ExtendScript:  app.documents[0].kescmSetPrintMarks(true);   // print the marks
			Method
			{
				kKESCMSetPrintMarksMethodScriptElement,
				e_KESCMSetPrintMarks,
				"kescm set print marks",
				"Makes the change marks appear when printing (and stay visible on screen while on).",
				StringType,
				"Status string",
				{
					p_KESCMPrintMarksFlag, "print", "kTrue to print the marks (default), kFalse to keep them screen-only", BoolDefaultType(kTrue), kOptional,
					p_KESCMPrintFaintFlag, "faint", "kTrue to print the marks at ~25% opacity, kFalse (default) for normal opacity", BoolDefaultType(kFalse), kOptional,
				}
			}

			// Connects this plug-in's methods and properties to scripting.
			Provider
		{
			kKESCMScriptProviderBoss,	// provider boss ID
			{
				Object{ kPageObjectScriptElement },
				Method{ kKESCMClearMarksMethodScriptElement },
				Method{ kKESCMToastMethodScriptElement },
				Method{ kKESCMSetPrintMarksMethodScriptElement },
			}
		}

		// Document-level: bulk mark across all pages + clear + peek/print toggles (same provider boss, Document object).
		Provider
		{
			kKESCMScriptProviderBoss,
			{
				Object{ kDocumentObjectScriptElement },
				Method{ kKESCMMarkChangesDocMethodScriptElement },
				Method{ kKESCMClearMarksMethodScriptElement },
				Method{ kKESCMArmMousePeekMethodScriptElement },
				Method{ kKESCMDisarmMousePeekMethodScriptElement },
				Method{ kKESCMToastMethodScriptElement },
				Method{ kKESCMSetPrintMarksMethodScriptElement },
			}
		}
	}
};


//========================================================================================
// ChangeMarker control panel (palette)
//========================================================================================

// PNG icons (compiled into the plug-in; ON = armed/comparing, OFF = idle). Same art is used for
// the normal and rollover states since this is a non-interactive status icon.
resource PNGA(kKESCMIconOnResID)  "KohakuExtendScriptChangeMarkerON64.png"
resource PNGR(kKESCMIconOnResID)  "KohakuExtendScriptChangeMarkerON64.png"
resource PNGA(kKESCMIconOffResID) "KohakuExtendScriptChangeMarkerOFF64.png"
resource PNGR(kKESCMIconOffResID) "KohakuExtendScriptChangeMarkerOFF64.png"

// Small dock-tab icon shown when the panel is collapsed to its smallest. Replace
// KohakuChangeMarkerTab.png with your own artwork (a small, e.g. ~20x20, transparent PNG).
resource PNGA(kKESCMPaletteIconResID) "KohakuChangeMarkerTab.png"

// Panel LocaleIndex - a single (string-key driven) view is used for every locale; the labels
// themselves are localized through the string tables (KESCM_enUS.fr / KESCM_jaJP.fr).
resource LocaleIndex (kSDKDefPanelResourceID)
{
	kViewRsrcType,
	{
		kWildFS, k_Wild, kSDKDefPanelResourceID + index_enUS
	}
};

// Type definition for the panel widget boss.
type KESCMPanelWidget(kViewRsrcType) : PalettePanelWidget(ClassID = kKESCMPanelWidgetBoss)
{
	CPanelMenuData;
};

// PanelList - registers the panel and makes it appear under the Window menu.
resource PanelList (kSDKDefPanelResourceID)
{
	{
		kSDKDefPanelResourceID,		// Resource ID for this panel
		kKESCMPluginID,				// owning plug-in
		kNotResizable,				// fixed-size panel
		kKESCMPanelWidgetActionID,	// Action ID to show/hide the panel
		"",							// panelName empty: place via altMenu below for explicit menu placement
		kKESCMPanelPluginsMenuPath,	// Plug-Ins > KohakuNekotarou > KohakuChangeMarker
		kKESCMPanelPluginsMenuPosition,	// lower part of the menu
		kKESCMPaletteIconResID, kKESCMPluginID,	// PNG icon for the collapsed dock tab
		c_Panel
	}
};

// PanelView - widget layout. Labels reference string keys so they localize automatically.
resource KESCMPanelWidget(kSDKDefPanelResourceID + index_enUS)
{
	__FILE__, __LINE__,
	kKESCMPanelWidgetID,			// WidgetID
	kPMRsrcID_None,					// RsrcID
	kBindNone,						// Binding
	0, 0, 240, 580,					// Frame: left, top, right, bottom
	kTrue, kTrue,					// Visible, Enabled
	kFalse,							// Erase background
	kInterfacePaletteFill,			// Erase to color
	kFalse,							// Draw dropshadow
	kKESCMPanelTitleKey,			// Panel name
	{
		// Target / Source status (label stays English; the document name is filled in by the observer).
		StaticTextWidget
		(
			kKESCMTargetTextWidgetID,
			kSysStaticTextPMRsrcId,
			kBindLeft | kBindRight | kBindTop,
			Frame(8, 8, 232, 24)
			kTrue, kTrue,
			kAlignLeft, kEllipsizeEnd, kTrue,
			"Target:",
			kInvalidWidgetID,
		),
		StaticTextWidget
		(
			kKESCMSourceTextWidgetID,
			kSysStaticTextPMRsrcId,
			kBindLeft | kBindRight | kBindTop,
			Frame(8, 26, 232, 42)
			kTrue, kTrue,
			kAlignLeft, kEllipsizeEnd, kTrue,
			"Source:",
			kInvalidWidgetID,
		),

		// Separator.
		SeparatorWidget
		(
			kInvalidWidgetID, kPMRsrcID_None,
			kBindLeft | kBindRight | kBindTop,
			Frame(0, 48, 240, 50)
			kTrue, kTrue,
		),

		// Start / Clear buttons.
		ButtonWidget
		(
			kKESCMStartButtonWidgetID,
			kSysButtonPMRsrcId,
			kBindLeft | kBindRight | kBindTop,
			Frame(12, 56, 228, 80)
			kTrue, kTrue,
			kKESCMStartButtonKey,
		),
		ButtonWidget
		(
			kKESCMClearButtonWidgetID,
			kSysButtonPMRsrcId,
			kBindLeft | kBindRight | kBindTop,
			Frame(12, 84, 228, 108)
			kTrue, kTrue,
			kKESCMClearButtonKey,
		),

		// Print marks checkbox.
		CheckBoxWidget
		(
			kKESCMPrintCheckWidgetID,
			kSysCheckBoxPMRsrcId,
			kBindLeft | kBindTop,
			Frame(12, 116, 228, 132)
			kTrue, kTrue,
			kAlignLeft,
			kKESCMPrintCheckKey,
		),

		// Print opacity (25% / Normal). Order 25% -> Normal, default 25% (set by the observer).
		ClusterPanelWidget
		(
			kKESCMOpacityClusterWidgetID,
			kPMRsrcID_None,
			kBindLeft | kBindTop,
			Frame(12, 138, 228, 188)
			kTrue, kTrue,
			"",
			{
				RadioButtonWidget
				(
					kKESCMOpacity25RadioWidgetID,
					kSysRadioButtonPMRsrcId,
					kBindNone,
					Frame(6, 4, 210, 20)
					kTrue, kTrue,
					kKESCMOpacity25Key,
				),
				RadioButtonWidget
				(
					kKESCMOpacityNormalRadioWidgetID,
					kSysRadioButtonPMRsrcId,
					kBindNone,
					Frame(6, 24, 210, 40)
					kTrue, kTrue,
					kKESCMOpacityNormalKey,
				),
			}
		),

		// Usage hint (gesture reference).
		StaticMultiLineTextWidget
		(
			kKESCMHintTextWidgetID,
			kPMRsrcID_None,
			kBindLeft | kBindRight | kBindTop,
			Frame(8, 194, 232, 452)
			kTrue, kTrue,
			kAlignLeft, kDontEllipsize, kTrue,
			kInvalidWidgetID,
			kPaletteWindowFontId,
			3,
			0, 0,
			kKESCMHintKey,
		),

		// Status icon (OFF visible by default; the observer swaps ON/OFF based on the armed state).
		RollOverIconButtonWidget
		(
			kKESCMIconOffWidgetID,
			kKESCMIconOffResID, kKESCMPluginID,
			kBindTop,
			Frame(88, 458, 152, 522)
			kTrue, kTrue,
			kADBEIconSuiteButtonType,
		),
		RollOverIconButtonWidget
		(
			kKESCMIconOnWidgetID,
			kKESCMIconOnResID, kKESCMPluginID,
			kBindTop,
			Frame(88, 458, 152, 522)
			kFalse, kTrue,
			kADBEIconSuiteButtonType,
		),

		// Status text (filled in by the observer with the result of each action).
		StaticMultiLineTextWidget
		(
			kKESCMStatusTextWidgetID,
			kPMRsrcID_None,
			kBindLeft | kBindRight | kBindBottom,
			Frame(8, 528, 232, 576)
			kTrue, kTrue,
			kAlignLeft, kDontEllipsize, kTrue,
			kInvalidWidgetID,
			kPaletteWindowFontId,
			3,
			2, 0,
			"",
		),
	}

	kKESCMInternalPopupMenuNameKey		// Popup (flyout) menu name (internal)
};

