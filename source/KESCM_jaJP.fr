#ifdef __ODFRC__


// Japanese string table is defined here

resource StringTable (kSDKDefStringsResourceID + index_jaJP)
{
        k_jaJP,	// Locale Id
        kResourceUTF8Encoded,	// Character encoding converter (this file is UTF-8, no BOM)

        {
        	// ----- Menu strings
                kKESCMCompanyKey,					"Kohaku Plug-Ins",	// 日本語ロケールも英語表記で統一(会社名 kKESCMCompanyValue とは別)
                kKESCMAboutMenuKey,					kKESCMPluginName "[JP]...",
                kKESCMPluginsMenuKey,				kKESCMPluginName "[JP]",

                // SDKDef.h の kSDKDefAboutThisPlugInMenuValue_jaJP は Shift-JIS 定義のため、UTF-8
                // テーブル(kResourceUTF8Encoded)では使えない。UTF-8 リテラルで同じ文言を直接記述する。
                kSDKDefAboutThisPlugInMenuKey,			"このプラグインについて…(&U)",
                kKESCMAboutScriptMenuKey,			"スクリプトについて…",

                // ----- Command strings

                // ----- Window strings

                // ----- Panel/dialog strings
                kKESCMPanelTitleKey,			"KohakuChangeMarker",
                kKESCMStartButtonKey,			"開始",
                kKESCMClearButtonKey,			"解除",
                kKESCMPrintCheckKey,			"比較枠の印刷",
                kKESCMOpacity25Key,				"25%",
                kKESCMOpacityNormalKey,			"通常",
                kKESCMHintKey,					"<ShiftCtrlAltは離せます>\n中マウスボタン=\n　25%比較枠(押中)\n中マウスボタン+Shift=\n　元(押中)\n中マウスボタン+Alt=\n　元50%(押中)\n中マウスボタン+Ctrl=\n　スプレッド単位の比較更新\n中マウスボタン+Shift+Alt=\n　比較枠(押中)\n中マウスボタン+Shift+Ctrl+Alt=\n　色情報(押中)",

              // ----- Error strings

                // ----- Misc strings
                kKESCMAboutBoxStringKey,			kKESCMPluginName "、version " kKESCMVersion "\n\n"
                	"Adobe InDesign C++ SDK プラグイン。\n"
                	"二つのドキュメントをページ単位でオフスクリーンにレンダリングしてピクセル比較し、変化した箇所を画面上に赤い枠で重ねて表示します。表示は非永続なので、ドキュメントには残りません。\n\n"
                	"本プラグインは KohakuNekotarou が、Anthropic の AI Claude（Claude Code）と協働して設計・実装しました。\n\n"
                	"【注意】どのような問題が起こっても責任を取れません。ご利用は自己責任でお願いします。\n\n"
                	"ソース: https://github.com/KohakuNekotarou/KohakuExtendScriptChangeMarker",

                kKESCMScriptHelpStringKey,			"KohakuChangeMarker — スクリプト\n\n"
                	"  Document.kescmToast(message)\n"
                	"    アクティブドキュメントのレイアウトウィンドウの\n"
                	"    表示部分の中央に message を少しの間表示し、約2.5秒で\n"
                	"    自動的に消えます。画面表示のみ・非永続です。\n"
                	"    戻り値はステータス文字列。\n\n"
                	"例:\n"
                	"  app.activeDocument.kescmToast('こんにちは');\n"
                	"  app.documents[0].kescmToast('完了！');",

        }

};

#endif // __ODFRC__
