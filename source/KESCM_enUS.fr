#ifdef __ODFRC__

// English string table is defined here

resource StringTable (kSDKDefStringsResourceID + index_enUS)
{
        k_enUS,									// Locale Id
        kEuropeanWinToMacEncodingConverter,		// Character encoding converter (irp) I made this WinToMac as we have a bias to generate on Win...
        {
        	 // ----- Menu strings
                kKESCMCompanyKey,					"Kohaku Plug-Ins",	// メニュー束ね名(表示)。会社名 kKESCMCompanyValue とは別概念で固定
                kKESCMAboutMenuKey,					kKESCMPluginName "[US]...",
                kKESCMPluginsMenuKey,				kKESCMPluginName "[US]",
	
                kSDKDefAboutThisPlugInMenuKey,			kSDKDefAboutThisPlugInMenuValue_enUS,
                kKESCMAboutScriptMenuKey,			"About Scripting...",

                // ----- Command strings

                // ----- Window strings

                // ----- Panel/dialog strings
                kKESCMPanelTitleKey,			"KohakuChangeMarker",
                kKESCMStartButtonKey,			"Start",
                kKESCMClearButtonKey,			"Clear",
                kKESCMPrintCheckKey,			"Print comparison marks",
                kKESCMOpacity25Key,				"25%",
                kKESCMOpacityNormalKey,			"Normal",
                kKESCMHintKey,					"<Shift/Ctrl/Alt can be released>\nMiddle button =\n  25% marks (while held)\nMiddle + Shift =\n  original (while held)\nMiddle + Alt =\n  original 50% (while held)\nMiddle + Ctrl =\n  refresh spread compare\nMiddle + Shift+Alt =\n  marks (while held)\nMiddle + Shift+Ctrl+Alt =\n  color info (while held)",

		// ----- Misc strings
                kKESCMAboutBoxStringKey,			kKESCMPluginName ", version " kKESCMVersion "\n\n"
                	"Adobe InDesign C++ SDK Plug-In.\n"
                	"Renders two documents page by page off-screen, compares them pixel by pixel, and overlays red frames on screen where changes are found. The overlay is non-persistent and is never saved into the document.\n\n"
                	"Designed and implemented by KohakuNekotarou in collaboration with Anthropic's AI Claude (Claude Code).\n\n"
                	"DISCLAIMER: Provided as-is. We cannot take responsibility for any problems that may arise. Use at your own risk.\n\n"
                	"Source: https://github.com/KohakuNekotarou/KohakuExtendScriptChangeMarker",

                kKESCMScriptHelpStringKey,			"KohakuChangeMarker - Scripting\n\n"
                	"  Document.kescmToast(message)\n"
                	"    Shows a brief message at the center of the active\n"
                	"    document's layout window, auto-dismissing after\n"
                	"    about 2.5 seconds. Screen only; nothing is saved\n"
                	"    into the document. Returns a status string.\n\n"
                	"Examples:\n"
                	"  app.activeDocument.kescmToast('Hello');\n"
                	"  app.documents[0].kescmToast('Done!');",


        }

};

#endif // __ODFRC__
